# Copy this file to .env.local and fill in your values.
# This file is NOT gitignored — it's safe to commit as an example.
# .env.local IS gitignored — your real values stay private.

# Your Halseth worker URL (no trailing slash)
HALSETH_URL=https://halseth.YOUR-ACCOUNT.workers.dev

# Same value as ADMIN_SECRET set in your Halseth worker.
# Required for the dashboard to post notes and update house state (spoons, love-o-meter).
HALSETH_SECRET=
